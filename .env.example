# Gemini Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=768

# Qdrant Configuration
# For local development with Docker Compose
QDRANT_URL=http://localhost:6333

# For production with external Qdrant instance
# QDRANT_URL=http://your-qdrant-host:6333
# QDRANT_API_KEY=your_qdrant_api_key_here  # Optional, only for Qdrant Cloud

# Service Configuration
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000

# Logging Configuration
# ENVIRONMENT: "development" (colored console logs) or "production" (JSON logs)
ENVIRONMENT=development

# LOG_LEVEL: TRACE, DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# LOG_DIR: Directory for log files (relative or absolute path)
LOG_DIR=./logs

# LOG_RETENTION_DAYS: Number of days to keep old log files
LOG_RETENTION_DAYS=30

# LOG_ROTATION_SIZE: Maximum log file size before rotation (e.g., "100 MB", "500 MB", "1 GB")
LOG_ROTATION_SIZE=100 MB
