# ---------------------------------------------------------------------------
# Weaviate
# ---------------------------------------------------------------------------
# For local docker-compose, WEAVIATE_HOST is the service name `weaviate`.
# Ports are fixed by the compose file.
WEAVIATE_HOST=weaviate
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_COLLECTION=Document
# WEAVIATE_API_KEY=   # only needed if Weaviate is secured (prod, WCS)

# ---------------------------------------------------------------------------
# Embedder
# ---------------------------------------------------------------------------
# "st"     = sentence-transformers local model (default, no API key).
# "gemini" = Google Gemini (requires GEMINI_API_KEY).
EMBEDDER_BACKEND=st
ST_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# Optional: set only if you want the /generate endpoint or the gemini embedder.
# GEMINI_API_KEY=
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_GENERATIVE_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Service
# ---------------------------------------------------------------------------
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000

# API_KEY gates all /tenants/** endpoints via X-API-Key header.
# Required when ENVIRONMENT=production.
API_KEY=change-me-before-deploying

# Comma-separated CORS origins. Empty = no cross-origin requests allowed.
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# Per-IP requests per minute.
RATE_LIMIT_PER_MINUTE=120

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_RETENTION_DAYS=30
LOG_ROTATION_SIZE=100 MB
ENABLE_METRICS=true
