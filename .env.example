# ==============================================================================
# RAGmodel service configuration
# Copy to `.env` and edit. Never commit the real .env.
# ==============================================================================

# -------- Embedder (local, open-source; no external API keys required) --------
# Backend: "sentence-transformers" (default) | "fastembed"
EMBEDDER_BACKEND=sentence-transformers

# HuggingFace model id. Default is BAAI/bge-small-en-v1.5 (384-dim, Apache 2.0).
EMBEDDER_MODEL=BAAI/bge-small-en-v1.5

# Vector dimension — must match the model above.
# bge-small-en-v1.5 = 384, bge-base-en-v1.5 = 768, bge-large-en-v1.5 = 1024
EMBEDDING_DIMENSION=384

# Optional: force CPU / CUDA. Leave blank for auto-detect.
EMBEDDER_DEVICE=

# -------- Qdrant --------
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=   # only for Qdrant Cloud / secured instances
QDRANT_TIMEOUT=30

# Physical collection name. All tenants share this one collection (Qdrant MT
# best practice — one HNSW graph, many tenants isolated by payload index).
QDRANT_COLLECTION=ragmodel

# Hybrid search: dense + sparse, fused server-side with RRF.
HYBRID_SEARCH_ENABLED=true
SPARSE_MODEL=Qdrant/bm25

# -------- Service --------
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000

# Comma-separated list of allowed origins. Use specific origins in production.
# e.g. CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# X-API-Key header value. If unset in non-development, startup refuses.
API_KEY=change-me-in-production

# Separate key required for admin endpoints (e.g. snapshots, which act on the
# shared physical collection). If unset in production, admin routes are disabled.
ADMIN_API_KEY=

# Rate limit applied to write + search endpoints (slowapi syntax).
RATE_LIMIT=60/minute

# -------- Observability --------
# ENVIRONMENT: "development" or "production"
ENVIRONMENT=development
LOG_LEVEL=INFO

# Expose /metrics (Prometheus). Set to "false" to disable.
METRICS_ENABLED=true
